{
    "name": "devops-backend",
    "version": "1.0.0",
    "description": "Node.js API for DevOps pipeline demo",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "nodemon src/index.js",
        "test": "jest --forceExit --detectOpenHandles",
        "test:ci": "jest --forceExit --detectOpenHandles --reporters=default --reporters=jest-junit"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "pg": "^8.11.3",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "jest-junit": "^16.0.0",
        "nodemon": "^3.0.2",
        "supertest": "^6.3.3"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ]
    }
}